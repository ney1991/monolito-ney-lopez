APP_NAME=GymMonolith
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stderr
LOG_LEVEL=debug

# --- PostgreSQL ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gym
DB_USERNAME=gym
DB_PASSWORD=secret

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=domain_events
RABBITMQ_DLX=domain_events.dlx
RABBITMQ_MAX_RETRIES=3

# --- API externa de frases (solo la usa el adaptador de infraestructura) ---
QUOTES_API_URL=https://dummyjson.com/quotes/random
QUOTES_API_TIMEOUT=3.0

CACHE_STORE=file
